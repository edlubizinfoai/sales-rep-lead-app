# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser. Required by the Stripe webhook,
# which has no user session and must bypass RLS to write subscriptions.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_

# Webhook secret — from Stripe dashboard → Webhooks → your endpoint
# For local dev: stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_

# Price ID for the $19/mo Pro plan — from Stripe dashboard → Products
STRIPE_PRICE_ID=price_

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
